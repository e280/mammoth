{
	"name": "@e280/mammoth",
	"version": "0.1.0-11",
	"description": "big file storage",
	"license": "MIT",
	"author": "Chase Moskal <chasemoskal@gmail.com>",
	"type": "module",
	"main": "./x/index.js",
	"sideEffects": false,
	"exports": {
		".": "./x/core/index.js",
		"./browser": "./x/browser/index.js",
		"./node": "./x/node/index.js"
	},
	"files": [
		"x",
		"s"
	],
	"scripts": {
		"build": "rm -rf x && mkdir x && tsc",
		"dev": "octo 'tsc -w' 'node --watch x/test.js'",
		"test": "node x/test.js",
		"count": "find s -path '*/_archive' -prune -o -name '*.ts' -exec wc -l {} +"
	},
	"peerDependencies": {
		"@e280/kv": "^0.1.5"
	},
	"dependencies": {
		"@e280/stz": "^0.3.5",
		"@noble/hashes": "^2.2.0"
	},
	"devDependencies": {
		"@e280/octo": "^0.1.3",
		"@e280/science": "^0.1.11",
		"@types/node": "^26.1.1",
		"typescript": "^7.0.2"
	},
	"allowScripts": {
		"classic-level@3.0.0": true
	},
	"keywords": [],
	"homepage": "https://github.com/e280/mammoth#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/e280/mammoth.git"
	},
	"bugs": {
		"url": "https://github.com/e280/mammoth/issues"
	}
}
